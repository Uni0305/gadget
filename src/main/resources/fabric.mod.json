{
    "schemaVersion": 1,
    "id": "gadget",
    "version": "${version}",

    "name": "gadget",
    "description": "Debugger's Delight",
    "authors": [
        "BasiqueEvangelist"
    ],
    "contributors": [
        "Kas-tle"
    ],
    "contact": {
        "homepage": "https://modrinth.com/mod/gadget",
        "sources": "https://github.com/BasiqueEvangelist/Gadget",
