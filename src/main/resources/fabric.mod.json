                "modmenu.wiki": "https://docs.wispforest.io/gadget/"
            }
        }
    },

    "depends": {
        "fabricloader": ">=0.13.3",
        "fabric-api": ">=0.77.0",
        "minecraft": ">=1.21",
        "java": ">=17",
        "owo": ">=0.11.1",
        "fabric-permissions-api-v0": ">=0.3.1"
